".\objects\main.o"
".\objects\startup.o"
--ro-base 0x10000000 --entry 0x10000000 --rw-base 0x20000000 --entry Reset_Handler --first __Vectors --strict --summary_stderr --info summarysizes --map --load_addr_map_info --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
